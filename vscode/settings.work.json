{
  "files.autoSave": "onFocusChange",
  "editor.fontFamily": "FiraCode Nerd Font Mono",
  "editor.renderWhitespace": "all",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "Catppuccin Frappé",
  "yaml.schemas": {
    "file:///Users/jorson/.vscode/extensions/docsmsft.docs-yaml-1.0.5/dist/toc.schema.json": "/toc\\.yml/i"
  },
  "redhat.telemetry.enabled": false,
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "git.ignoreMissingGitWarning": true,
  "cSpell.userWords": [
    "agentpool",
    "azuread",
    "azurerm",
    "eastus",
    "eldership",
    "snet",
    "vnet"
  ],
  "sonarlint.rules": {
    "terraform:S1135": {
      "level": "off"
    },
    "csharpsquid:S6602": {
      "level": "off"
    }
  },
  "FSharp.suggestGitignore": false,
  "git.openRepositoryInParentFolders": "always",
  "calva.prettyPrintingOptions": {
    "printEngine": "pprint",
    "enabled": false,
    "width": 120,
    "maxLength": 50
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "githubPullRequests.pullBranch": "never",
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.stickyScroll.enabled": false,
  "git.replaceTagsWhenPull": true,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "makefile.configureOnOpen": false,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.associations": {
    "*.json": "json"
  },
  "extensions.trustedPublishers": [
    "aykutsarac",
    "bierner",
    "davidanson",
    "eamodio",
    "esbenp",
    "golang",
    "gruntfuggly",
    "hashicorp",
    "janisdd",
    "kosunix",
    "mattn",
    "mechatroner",
    "monokai",
    "naumovs",
    "pascalreitermann93",
    "pkief",
    "quicktype",
    "rangav",
    "redhat",
    "richie5um2",
    "sjhuangx",
    "streetsidesoftware",
    "tamasfe",
    "tyriar",
    "ultram4rine",
    "yandeu",
    "zainchen"
  ],
  "git.alwaysSignOff": true,
  "git.enableCommitSigning": true,
  "terminal.integrated.suggest.enabled": false,
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "docker.extension.enableComposeLanguageServer": false,
  "sonarlint.connectedMode.connections.sonarqube": [
    {
      "serverUrl": "https://sonarqube.dx-tooling-prd.purestorage.com",
      "connectionId": "Sonarqube DX"
    }
  ],
  "claudeCode.disableLoginPrompt": true,
  "claude-code.enableAuthLogin": true,
  "claudeCode.environmentVariables": [
    {
      "name": "ANTHROPIC_DEFAULT_OPUS_MODEL",
      "value": "claude-opus-4-7"
    },
    {
      "name": "ANTHROPIC_DEFAULT_SONNET_MODEL",
      "value": "claude-sonnet-4-6"
    },
    {
      "name": "ANTHROPIC_DEFAULT_HAIKU_MODEL",
      "value": "claude-haiku-4-5"
    }
  ],
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.profiles.osx": {
    "bash": {
      "path": "bash",
      "args": [
        "-l"
      ],
      "icon": "terminal-bash"
    },
    "zsh": {
      "path": "/opt/homebrew/bin/zsh",
      "args": [
        "-l"
      ]
    },
    "fish": {
      "path": "fish",
      "args": [
        "-l"
      ]
    },
    "tmux": {
      "path": "tmux",
      "icon": "terminal-tmux"
    },
    "pwsh": {
      "path": "pwsh",
      "icon": "terminal-powershell"
    }
  },
  "terminal.integrated.agentHostProfile.osx": {
    "path": "/opt/homebrew/bin/zsh",
    "icon": ""
  },
  "vs-kubernetes": {
    "vscode-kubernetes.minikube-path-mac": "/Users/jorson/.vs-kubernetes/tools/minikube/darwin-arm64/minikube",
    "vscode-kubernetes.helm-path-mac": "/Users/jorson/.vs-kubernetes/tools/helm/darwin-arm64/helm",
    "vscode-kubernetes.kubectl-path-mac": "/Users/jorson/.vs-kubernetes/tools/kubectl/kubectl"
  },
  "todo-tree.ripgrep.ripgrep": "/opt/homebrew/bin/rg",
  "chat.viewSessions.orientation": "stacked",
  "yaml.disableSchemaDetection": [
    "**/.github/workflows/*.yml",
    "**/.github/workflows/*.yaml",
    "**/.gitea/workflows/*.yml",
    "**/.gitea/workflows/*.yaml",
    "**/.forgejo/workflows/*.yml",
    "**/.forgejo/workflows/*.yaml"
  ],
  "gitlens.advanced.messages": {
    "suppressIntegrationDisconnectedTooManyFailedRequestsWarning": true
  }
}
